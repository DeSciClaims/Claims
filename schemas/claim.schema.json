{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "paper_id",
    "claim_text",
    "subject",
    "predicate",
    "object",
    "claim_kind",
    "epistemic_status",
    "support_origin",
    "source_span_ids"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "paper_id": {
      "type": "string"
    },
    "claim_text": {
      "type": "string"
    },
    "subject": {
      "$ref": "#/$defs/semantic_field"
    },
    "predicate": {
      "$ref": "#/$defs/semantic_field"
    },
    "object": {
      "$ref": "#/$defs/semantic_field"
    },
    "claim_kind": {
      "type": "string",
      "enum": [
        "result",
        "background",
        "hypothesis",
        "method",
        "interpretation",
        "causal",
        "correlational",
        "descriptive"
      ]
    },
    "epistemic_status": {
      "type": "string",
      "enum": [
        "empirical",
        "conjectural",
        "theoretical",
        "cited",
        "inferred",
        "mixed"
      ]
    },
    "support_origin": {
      "type": "string",
      "enum": [
        "own_results",
        "cited_results",
        "background",
        "methodological",
        "speculative"
      ]
    },
    "source_span_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/semantic_field"
      }
    },
    "details": {
      "type": "object"
    },
    "extractor_confidence": {
      "type": "number"
    }
  },
  "$defs": {
    "ontology_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_source", "ontology_id", "ontology_label"],
      "properties": {
        "ontology_source": {
          "type": "string"
        },
        "ontology_id": {
          "type": "string"
        },
        "ontology_label": {
          "type": "string"
        },
        "match_type": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      }
    },
    "ontology_annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotation_type",
        "mapping_status",
        "candidate_mappings",
        "selected_mapping",
        "mapping_method"
      ],
      "properties": {
        "annotation_type": {
          "type": "string",
          "enum": ["mapping", "classification"]
        },
        "raw_text": {
          "type": "string"
        },
        "normalized_text": {
          "type": "string"
        },
        "mapping_status": {
          "type": "string",
          "enum": ["mapped", "ambiguous", "unresolved", "rejected"]
        },
        "candidate_mappings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ontology_candidate"
          }
        },
        "selected_mapping": {
          "anyOf": [
            {
              "$ref": "#/$defs/ontology_candidate"
            },
            {
              "type": "null"
            }
          ]
        },
        "mapping_method": {
          "type": "string"
        }
      }
    },
    "semantic_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string"
        },
        "entity_type": {
          "type": "string"
        },
        "ontology": {
          "anyOf": [
            {
              "$ref": "#/$defs/ontology_annotation"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
