{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaimFrame",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "claim_text",
    "subject",
    "predicate",
    "object",
    "claim_type",
    "epistemic_status",
    "source_chunk_ids"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "claim_text": {
      "type": "string"
    },
    "subject": {
      "$ref": "#/$defs/semantic_field"
    },
    "predicate": {
      "$ref": "#/$defs/semantic_field"
    },
    "object": {
      "$ref": "#/$defs/semantic_field"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "causal",
        "correlational",
        "comparative",
        "prevalence",
        "methodological",
        "definitional",
        "null_result"
      ]
    },
    "epistemic_status": {
      "type": "string",
      "enum": [
        "reported",
        "supported",
        "qualified",
        "contradicted",
        "uncertain"
      ]
    },
    "source_chunk_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    }
  },
  "$defs": {
    "ontology_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_source", "ontology_id", "ontology_label"],
      "properties": {
        "ontology_source": {
          "type": "string"
        },
        "ontology_id": {
          "type": "string"
        },
        "ontology_label": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        }
      }
    },
    "semantic_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string"
        },
        "normalized_value": {
          "type": "string"
        },
        "selected_mapping": {
          "$ref": "#/$defs/ontology_candidate"
        },
        "candidate_mappings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ontology_candidate"
          }
        }
      }
    }
  }
}
